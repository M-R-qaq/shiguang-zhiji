# 食光知己后端配置模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# LLM API 配置 (必填)
# ===========================================
# API接口格式兼容OpenAI，可使用：
# - OpenAI官方: https://api.openai.com/v1
# - 国内中转API: 如 https://api.deepseek.com/v1
# - 其他兼容API: 如 https://your-proxy.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 你的API Key（根据所使用的中转服务填写）
OPENAI_API_KEY=your-api-key-here

# 使用的模型（根据API服务商支持的模型填写）
LLM_MODEL=gpt-3.5-turbo

# ===========================================
# TTS 语音合成配置
# ===========================================
TTS_MODEL=tts-1
# 可选音色: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova

# ===========================================
# Whisper 语音识别配置
# ===========================================
# 可选模型: tiny, base, small, medium, large
# 模型越大精度越高，但需要更多内存
WHISPER_MODEL=base

# ===========================================
# JWT 安全配置 (必填)
# ===========================================
# 生成随机密钥的方法：在Python中运行
# import secrets; print(secrets.token_hex(32))
SECRET_KEY=your-secret-key-change-in-production

# Token过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# 服务器配置
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./shiguang.db