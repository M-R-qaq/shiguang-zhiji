# 食光知己后端配置模板
# 复制此文件为 .env 并填写实际值

# ===========================================
# LLM API 配置 (必填)
# ===========================================
# API接口格式兼容OpenAI，可使用：
# - OpenAI官方: https://api.openai.com/v1
# - 国内中转API: 如 https://api.deepseek.com/v1
# - 其他兼容API: 如 https://your-proxy.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 你的API Key（根据所使用的中转服务填写）
OPENAI_API_KEY=your-api-key-here

# 使用的模型（根据API服务商支持的模型填写）
LLM_MODEL=gpt-3.5-turbo

# ===========================================
# TTS 语音合成配置
# ===========================================
# TTS供应商选择: openai, iflytek_ws, mimo
TTS_PROVIDER=openai

# --- OpenAI TTS ---
TTS_MODEL=tts-1
# 可选音色: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova

# --- 讯飞 TTS (iflytek_ws) ---
# IFLYTEK_TTS_APP_ID=your-app-id
# IFLYTEK_TTS_API_KEY=your-api-key
# IFLYTEK_TTS_API_SECRET=your-api-secret

# --- MiMo TTS (mimo-v2.5-tts-voicedesign) ---
# 通过音色描述定制苏怀真的专属声音
# MIMO_API_KEY=your-mimo-api-key
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_TTS_MODEL=mimo-v2.5-tts-voicedesign
# MIMO_VOICE_DESIGN_PROMPT=一位中年男性文人，嗓音醇厚温润，带着岁月沉淀的沧桑感。语速不疾不徐，娓娓道来，像一位饱读诗书的老友在餐桌旁与你闲聊。偶尔带着一丝豁达的笑意，声音中有文人的儒雅和智者的从容。半文半白的语言风格，温暖而不失风趣。

# --- TTS 缓存配置 ---
# 启用TTS音频缓存，相同文本直接返回缓存结果
TTS_CACHE_ENABLED=true
# 缓存过期时间（秒），默认24小时
TTS_CACHE_TTL=86400
# 最大缓存条目数，超出按LRU淘汰
TTS_CACHE_MAX_ENTRIES=500

# --- TTS 流式合成配置 ---
# 启用SSE流式TTS合成（讯飞原生流式，MiMo伪流式）
TTS_STREAMING_ENABLED=true

# --- TTS 健康检测与降级配置 ---
# 健康检测间隔（秒），0表示禁用
TTS_HEALTH_CHECK_INTERVAL=300
# 提供商降级顺序（逗号分隔）
TTS_FALLBACK_ORDER=mimo,iflytek_ws,openai

# --- TTS 音频格式配置 ---
# 目标音频格式（mp3或wav）
TTS_AUDIO_FORMAT=mp3
# MP3编码比特率
TTS_MP3_BITRATE=128k

# ===========================================
# Whisper 语音识别配置
# ===========================================
# 可选模型: tiny, base, small, medium, large
# 模型越大精度越高，但需要更多内存
WHISPER_MODEL=base

# ===========================================
# JWT 安全配置 (必填)
# ===========================================
# ⚠️ 生产环境必须修改！使用默认值有安全风险
# 生成随机密钥的方法：在Python中运行
# import secrets; print(secrets.token_hex(32))
SECRET_KEY=your-secret-key-change-in-production

# Token过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===========================================
# CORS 跨域配置
# ===========================================
# 允许的来源域名，多个用逗号分隔，* 表示允许所有
# 生产环境建议限制具体域名，如: http://localhost:3000,http://192.168.1.100:8081
CORS_ORIGINS=*

# ===========================================
# 服务器配置
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ===========================================
# 数据库配置
# ===========================================
DATABASE_URL=sqlite+aiosqlite:///./shiguang.db

# ===========================================
# 联网搜索配置 (Tavily API)
# ===========================================
# 启用联网搜索功能（需要Tavily API Key）
# 免费注册: https://tavily.com 免费额度1000次/月
WEB_SEARCH_ENABLED=true

# Tavily API Key（从 https://app.tavily.com 获取）
TAVILY_API_KEY=your-tavily-api-key-here

# 搜索返回最大结果数（1-10）
WEB_SEARCH_MAX_RESULTS=3

# 搜索超时时间（秒）
WEB_SEARCH_TIMEOUT=10

